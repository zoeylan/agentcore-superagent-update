{
  "name": "super-agent-agentcore-runner",
  "version": "1.0.0",
  "type": "module",
  "description": "AgentCore Runtime container — runs Claude Agent SDK inside AWS Bedrock AgentCore",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@aws-sdk/client-bedrock-agentcore": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
