  app_id      String   @db.Uuid
  user_id     String?  @db.Uuid
  org_id      String   @db.Uuid
  event_type  String
  duration_ms Int?
  metadata    Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz

  app          published_apps @relation(fields: [app_id], references: [id], onDelete: Cascade)
  organization organizations  @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([app_id])
  @@index([user_id])
  @@index([created_at(sort: Desc)])
}

// ============================================================================
// App Ratings — Reviews & Feedback
// ============================================================================
model app_ratings {
  id         String   @id @default(uuid()) @db.Uuid
  app_id     String   @db.Uuid
  user_id    String   @db.Uuid
  org_id     String   @db.Uuid
  rating     Int
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  app          published_apps @relation(fields: [app_id], references: [id], onDelete: Cascade)
  organization organizations  @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@unique([app_id, user_id])
  @@index([app_id])
}

// ============================================================================
// App Versions — Version History
// ============================================================================
model app_versions {
  id           String   @id @default(uuid()) @db.Uuid
  app_id       String   @db.Uuid
  version      String
  bundle_path  String
  changelog    String?
  published_by String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz

  app published_apps @relation(fields: [app_id], references: [id], onDelete: Cascade)

  @@index([app_id])
}

// ============================================================================
// Agent Events — Fact table for agent activity tracking
// ============================================================================
model agent_events {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  session_id      String?  @db.Uuid
  agent_id        String?  @db.Uuid
  target_agent_id String?  @db.Uuid
  event_type      String   @db.VarChar(50) // subagent_invocation, skill_usage, tool_call, error, turn_complete
  event_name      String?  @db.VarChar(255) // agent name, skill name, tool name
  metadata        Json     @default("{}")
  created_at      DateTime @default(now()) @db.Timestamptz

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, event_type, created_at(sort: Desc)])
  @@index([agent_id, event_type, created_at(sort: Desc)])
  @@index([target_agent_id, created_at(sort: Desc)])
  @@index([session_id])
  @@index([created_at(sort: Desc)])
}

// ============================================================================
// Agent Metrics Daily — Pre-aggregated rollup for dashboards
// ============================================================================
model agent_metrics_daily {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  agent_id        String   @db.Uuid
  metric_date     DateTime @db.Date
  event_type      String   @db.VarChar(50)
  event_name      String?  @db.VarChar(255)
  count           Int      @default(0)
  metadata        Json     @default("{}")
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, agent_id, metric_date, event_type, event_name], name: "unique_daily_metric")
  @@index([agent_id, metric_date])
  @@index([organization_id, metric_date])
}

// ============================================================================
// IM Channel Bindings — Maps IM channels to business scopes
// ============================================================================
model im_channel_bindings {
  id                 String   @id @default(uuid()) @db.Uuid
  organization_id    String   @db.Uuid
  business_scope_id  String?  @db.Uuid
  agent_id           String?  @db.Uuid // for agent-level IM bindings (digital twins)
  channel_type       String   @db.VarChar(50)
  channel_id         String   @db.VarChar(255)
  channel_name       String?  @db.VarChar(255)
  bot_token_enc      String?
  webhook_url        String?
  config             Json     @default("{}")
  is_enabled         Boolean  @default(true)
  sticky_session_id  String?  @db.Uuid // persistent session for non-threaded IM messages
  created_by         String?  @db.Uuid
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz

  organization    organizations        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  business_scope  business_scopes?     @relation(fields: [business_scope_id], references: [id], onDelete: Cascade)
  sticky_session  chat_sessions?       @relation("StickySession", fields: [sticky_session_id], references: [id], onDelete: SetNull)
  thread_sessions im_thread_sessions[]

  @@unique([organization_id, channel_type, channel_id], name: "unique_channel_binding")
  @@index([organization_id])
  @@index([business_scope_id])
  @@index([agent_id])
  @@index([channel_type, channel_id])
  @@index([is_enabled])
  @@index([sticky_session_id])
}

// ============================================================================
// IM Thread Sessions — Maps IM threads to chat sessions
// ============================================================================
model im_thread_sessions {
  id         String   @id @default(uuid()) @db.Uuid
  binding_id String   @db.Uuid
  thread_id  String   @db.VarChar(255) // platform-specific thread/conversation ID
  session_id String   @db.Uuid
  im_user_id String?  @db.VarChar(255) // platform user ID
  created_at DateTime @default(now()) @db.Timestamptz

  binding im_channel_bindings @relation(fields: [binding_id], references: [id], onDelete: Cascade)
  session chat_sessions       @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([binding_id, thread_id], name: "unique_thread_per_binding")
  @@index([binding_id])
  @@index([session_id])
}

// ============================================================================
// Scope Memories — Persistent knowledge accumulated per business scope
// ============================================================================
model scope_memories {
  id                String   @id @default(uuid()) @db.Uuid
  organization_id   String   @db.Uuid
  business_scope_id String   @db.Uuid
  session_id        String?  @db.Uuid
  title             String
  content           String
  category          String   @default("lesson")
  tags              String[] @default([])
  is_pinned         Boolean  @default(false)
  visibility        String   @default("scope") @db.VarChar(20)
  // 'scope': visible to all users (agent knowledge, business rules)
  // 'user': visible only to creator (personal preferences, patterns)
  // 'session': visible only within originating session
  created_by        String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  organization   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  business_scope business_scopes @relation(fields: [business_scope_id], references: [id], onDelete: Cascade)

  // pgvector embedding — managed via raw SQL, not Prisma ORM
  // embedding vector(1024)

  @@index([organization_id])
  @@index([business_scope_id])
  @@index([category])
  @@index([business_scope_id, is_pinned])
  @@index([created_at(sort: Desc)])
  @@index([business_scope_id, visibility])
  @@index([business_scope_id, created_by, visibility])
}

// ============================================================================
// Scope Briefings — AI-generated insights about scope activity
// ============================================================================
model scope_briefings {
  id                String @id @default(uuid()) @db.Uuid
  organization_id   String @db.Uuid
  business_scope_id String @db.Uuid

  title    String @db.VarChar(255)
  summary  String
  category String @db.VarChar(100)
  status   String @db.VarChar(50)

  source_type String  @db.VarChar(50)
  source_id   String  @db.VarChar(255)
  agent_id    String? @db.Uuid

  tags       Json @default("[]")
  metadata   Json @default("{}")
  importance Int  @default(5)

  event_time   DateTime  @db.Timestamptz
  generated_at DateTime  @default(now()) @db.Timestamptz
  expires_at   DateTime? @db.Timestamptz

  is_read     Boolean @default(false)
  is_archived Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  organization   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  business_scope business_scopes @relation(fields: [business_scope_id], references: [id], onDelete: Cascade)
  agent          agents?         @relation(fields: [agent_id], references: [id], onDelete: SetNull)

  @@unique([business_scope_id, source_type, source_id], name: "unique_briefing_source")
  @@index([business_scope_id, event_time(sort: Desc)])
  @@index([business_scope_id, status])
  @@index([business_scope_id, importance(sort: Desc)])
  @@index([business_scope_id, is_read])
  @@index([source_type, source_id])
}

// ============================================================================
// App Data — Per-app JSONB data storage for published mini-SaaS apps
// ============================================================================
model app_data {
  id         String   @id @default(uuid()) @db.Uuid
  app_id     String   @db.Uuid
  org_id     String   @db.Uuid
  collection String   @db.VarChar(100)
  data       Json
  created_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  app          published_apps @relation(fields: [app_id], references: [id], onDelete: Cascade)
  organization organizations  @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([app_id, collection])
  @@index([org_id])
  @@index([created_at(sort: Desc)])
}

// ============================================================================
// Document Groups — logical collections of reference documents
// ============================================================================
model document_groups {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  description     String?
  storage_path    String
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  organization          organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  files                 document_group_files[]
  scope_document_groups scope_document_groups[]

  @@unique([organization_id, name], name: "unique_doc_group_name_per_org")
  @@index([organization_id])
}

// ============================================================================
// Document Group Files — individual files within a document group
// ============================================================================
model document_group_files {
  id                String   @id @default(uuid()) @db.Uuid
  document_group_id String   @db.Uuid
  organization_id   String   @db.Uuid
  original_filename String
  stored_filename   String
  file_size         BigInt   @default(0)
  mime_type         String   @default("application/octet-stream")
  uploaded_by       String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz

  document_group document_groups @relation(fields: [document_group_id], references: [id], onDelete: Cascade)
  organization   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([document_group_id])
  @@index([organization_id])
}

// ============================================================================
// Scope ↔ Document Group assignments
// ============================================================================
model scope_document_groups {
  id                String   @id @default(uuid()) @db.Uuid
  organization_id   String   @db.Uuid
  business_scope_id String   @db.Uuid
  document_group_id String   @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz

  organization   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  business_scope business_scopes @relation(fields: [business_scope_id], references: [id], onDelete: Cascade)
  document_group document_groups @relation(fields: [document_group_id], references: [id], onDelete: Cascade)

  @@unique([business_scope_id, document_group_id])
  @@index([organization_id])
  @@index([business_scope_id])
  @@index([document_group_id])
}

// ============================================================================
// Chat Room Members — agents participating in a chat room (group mode)
// ============================================================================
model chat_room_members {
  id              String   @id @default(uuid()) @db.Uuid
  session_id      String   @db.Uuid
  agent_id        String   @db.Uuid
  role            String   @default("member") @db.VarChar(20) // primary | member
  is_active       Boolean  @default(true)
  added_by        String?  @db.Uuid
  source_scope_id String?  @db.Uuid // scope the agent belongs to (for cross-scope rooms)
  joined_at       DateTime @default(now()) @db.Timestamptz

  session chat_sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade)
  agent   agents         @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  scope   business_scopes? @relation("room_member_scope", fields: [source_scope_id], references: [id], onDelete: SetNull)

  @@unique([session_id, agent_id], name: "unique_room_member")
  @@index([session_id])
  @@index([agent_id])
  @@index([session_id, is_active])
}

// ============================================================================
// Agent Scope Assignments — M:N relationship for cross-scope agent reuse
// ============================================================================
model agent_scope_assignments {
  id                String   @id @default(uuid()) @db.Uuid
  agent_id          String   @db.Uuid
  business_scope_id String   @db.Uuid
  is_primary        Boolean  @default(false)
  assigned_at       DateTime @default(now()) @db.Timestamptz
  assigned_by       String?  @db.Uuid

  agent          agents          @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  business_scope business_scopes @relation(fields: [business_scope_id], references: [id], onDelete: Cascade)

  @@unique([agent_id, business_scope_id], name: "unique_agent_scope")
  @@index([agent_id])
  @@index([business_scope_id])
}

// ============================================================================
// Projects — Kanban boards for software development
// ============================================================================
model projects {
  id                   String   @id @default(uuid()) @db.Uuid
  organization_id      String   @db.Uuid
  name                 String
  description          String?
  repo_url             String?
  default_branch       String   @default("main")
  business_scope_id    String?  @db.Uuid
  agent_id             String?  @db.Uuid // the agent in charge of this project
  workspace_session_id String?  @db.Uuid // persistent chat session for the project agent
  settings             Json     @default("{}")
  created_by           String   @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz

  organization organizations     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  issues       project_issues[]
  members      project_members[]

  @@index([organization_id])
  @@index([created_by])
  @@index([agent_id])
  @@index([created_at(sort: Desc)])
}

// ============================================================================
// Project Members — who can access a project
// ============================================================================
model project_members {
  id         String   @id @default(uuid()) @db.Uuid
  project_id String   @db.Uuid
  user_id    String   @db.Uuid
  role       String   @default("member") @db.VarChar(20)
  joined_at  DateTime @default(now()) @db.Timestamptz

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id], name: "unique_project_member")
  @@index([project_id])
  @@index([user_id])
}

// ============================================================================
// Project Issues — task cards on the kanban board
// ============================================================================
model project_issues {
  id                   String   @id @default(uuid()) @db.Uuid
  project_id           String   @db.Uuid
  organization_id      String   @db.Uuid
  issue_number         Int
  title                String
  description          String?
  status               String   @default("backlog") @db.VarChar(20)
  priority             String   @default("medium") @db.VarChar(20)
  labels               Json     @default("[]")
  sort_order           Float    @default(0)
  branch_name          String?
  workspace_session_id String?  @db.Uuid
  pr_url               String?
  estimated_effort     String?
  parent_issue_id      String?  @db.Uuid
  created_by           String   @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz

  // AI governance fields
  readiness_score     Float? // 0-100 readiness score
  readiness_details   Json? // { completeness, conflicts, dependencies, executability }
  acceptance_criteria Json? // [{ criterion: string, verified: boolean }]
  ai_analysis_status  String?   @db.VarChar(20) // 'pending' | 'analyzing' | 'done' | 'stale'
  last_analyzed_at    DateTime? @db.Timestamptz

  // Code diff fields (populated by AgentCore after execution)
  diff_stat       Json? // { files_changed: number, insertions: number, deletions: number, files: [{ path, status, insertions, deletions }] }
  diff_patch      String? // Full unified diff text
  diff_created_at DateTime? @db.Timestamptz

  project             projects                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  organization        organizations             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  comments            project_issue_comments[]
  children            project_issues[]          @relation("issue_parent")
  parent              project_issues?           @relation("issue_parent", fields: [parent_issue_id], references: [id], onDelete: SetNull)
  relations_as_source project_issue_relations[] @relation("relation_source")
  relations_as_target project_issue_relations[] @relation("relation_target")

  @@unique([project_id, issue_number], name: "unique_issue_number_per_project")
  @@index([project_id])
  @@index([organization_id])
  @@index([status])
  @@index([priority])
  @@index([project_id, status])
  @@index([created_at(sort: Desc)])
}

