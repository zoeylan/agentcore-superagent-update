  agent_group_id    String? @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  agent_group  agent_groups? @relation(fields: [agent_group_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([business_scope_id])
  @@index([is_active])
  @@index([priority])
}

// ============================================================================
// Customer Service Module — CSAT Surveys
// ============================================================================
model csat_surveys {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  conversation_id String   @db.Uuid
  customer_id     String?  @db.Uuid
  rating          Int
  comment         String?
  channel_type    String?  @db.VarChar(20)
  submitted_at    DateTime @default(now()) @db.Timestamptz

  organization organizations          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  conversation support_conversations  @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([conversation_id])
  @@index([customer_id])
  @@index([submitted_at(sort: Desc)])
}

// ============================================================================
// Customer Service Module — Daily Metrics Aggregation
// ============================================================================
model support_metrics_daily {
  id                     String  @id @default(uuid()) @db.Uuid
  organization_id        String  @db.Uuid
  business_scope_id      String? @db.Uuid
  date                   DateTime @db.Date
  total_conversations    Int     @default(0)
  resolved_conversations Int     @default(0)
  ai_resolved            Int     @default(0)
  human_resolved         Int     @default(0)
  avg_first_response_sec Float?
  avg_resolution_sec     Float?
  avg_csat_rating        Float?
  csat_count             Int     @default(0)
  escalated_count        Int     @default(0)
  handoff_count          Int     @default(0)
  created_at             DateTime @default(now()) @db.Timestamptz
  updated_at             DateTime @default(now()) @updatedAt @db.Timestamptz

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, date, business_scope_id], name: "unique_daily_metrics")
  @@index([organization_id])
  @@index([date])
}

