// ============================================================================
// Skill Scan Results Table - LLM-powered security/compliance scanning
// ============================================================================
model skill_scan_results {
  id          String   @id @default(uuid()) @db.Uuid
  skill_id    String   @db.Uuid
  scan_type   String   @db.VarChar(32) // security | compliance | compatibility | license
  status      String   @default("pending") @db.VarChar(20) // pending | running | passed | warning | failed
  score       Float    @default(0)
  findings    Json     @default("[]")
  summary     String?
  scanned_at  DateTime @default(now()) @db.Timestamptz

  skill skills @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@index([skill_id])
  @@index([scan_type])
  @@index([scanned_at(sort: Desc)])
  @@index([skill_id, scan_type])
}

// ============================================================================
// Audit Logs Table — enterprise compliance (SOC 2, GDPR, 等保)
// ============================================================================
model audit_logs {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  actor_id        String   @db.Uuid
  actor_email     String?
  action          String   @db.VarChar(100) // e.g. agent.create, scope.member.add
  resource_type   String   @db.VarChar(50) // e.g. agent, scope, workflow, knowledge
  resource_id     String?  @db.Uuid
  resource_name   String?  // human-readable name of the affected resource
  scope_id        String?  @db.Uuid
  metadata        Json?    @db.JsonB // additional context (old/new values, params, etc.)
  ip_address      String?  @db.VarChar(45)
  user_agent      String?
  created_at      DateTime @default(now()) @db.Timestamptz

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([actor_id])
  @@index([action])
  @@index([resource_type])
  @@index([scope_id])
  @@index([created_at(sort: Desc)])
  @@index([organization_id, created_at(sort: Desc)])
  @@index([organization_id, action])
  @@index([organization_id, actor_id, created_at(sort: Desc)])
}
