{
  "name": "backend",
  "version": "1.0.0",
  "description": "Unified TypeScript backend for Super Agent Platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy"
  },
  "keywords": [
    "super-agent",
    "backend",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.37",
    "@aws-sdk/client-bedrock-agentcore": "^3.1011.0",
    "@aws-sdk/client-bedrock-runtime": "^3.969.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.992.0",
    "@aws-sdk/client-s3": "^3.966.0",
    "@aws-sdk/s3-request-presigner": "^3.966.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.4",
    "@fastify/websocket": "^11.2.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/js-yaml": "^4.0.9",
    "@wecom/aibot-node-sdk": "^1.0.6",
    "archiver": "^7.0.1",
    "aws-jwt-verify": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.2",
    "cron-parser": "^4.9.0",
    "dingtalk-stream": "^2.1.6-beta.1",
    "discord.js": "^14.26.2",
    "fastify": "^5.6.2",
    "ioredis": "^5.9.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "langfuse": "^3.38.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "sharp": "^0.34.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.6",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "fast-check": "^4.5.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "prisma": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
