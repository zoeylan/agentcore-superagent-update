# =============================================================================
# Super Agent Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/super_agent?schema=public

# =============================================================================
# Authentication
# =============================================================================

# Auth mode: 'local' (default, username/password with JWT) or 'cognito' (AWS Cognito SSO)
AUTH_MODE=local

# JWT secret for local auth mode (change this in production!)
# JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL (used for invite email links)
APP_URL=http://localhost:5173

# Cognito Configuration — only needed when AUTH_MODE=cognito
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_CLIENT_ID=your-cognito-client-id
# COGNITO_REGION=us-east-1
# COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
# COGNITO_AWS_ACCESS_KEY_ID=your-cognito-access-key
# COGNITO_AWS_SECRET_ACCESS_KEY=your-cognito-secret-key

# =============================================================================
# SMTP Configuration (for invite emails)
# =============================================================================
# Configure your enterprise SMTP server to enable email invitations.
# If not configured, invites are created but no email is sent.

# SMTP_HOST=smtp.your-company.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@your-company.com

# =============================================================================
# AWS Configuration
# =============================================================================
# Used for Bedrock (AI), S3 (storage), and other AWS services.
# Can also use system environment variables or ~/.aws/credentials instead.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 Configuration
S3_BUCKET_NAME=super-agent-files
S3_AVATARS_BUCKET=super-agent-avatars
S3_PRESIGNED_URL_EXPIRES=3600
SKILLS_S3_BUCKET=super-agent-skills

# =============================================================================
# Redis Configuration (for BullMQ workflow queues)
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# Claude Agent SDK
# =============================================================================

# Set to 1 to use Amazon Bedrock, or provide ANTHROPIC_API_KEY for direct API
CLAUDE_CODE_USE_BEDROCK=1
CLAUDE_MODEL=claude-sonnet-4-6

# Path to claude CLI executable (auto-detected if not set)
# CLAUDE_CODE_EXECUTABLE=/opt/homebrew/bin/claude

# Anthropic model ID for lightweight tasks (e.g. workflow generation)
# ANTHROPIC_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Direct Anthropic API key (alternative to Bedrock)
# ANTHROPIC_API_KEY=sk-ant-...

# Workspace directories
AGENT_WORKSPACE_BASE_DIR=/tmp/workspaces
DOC_GROUPS_BASE_PATH=/tmp/super-agent-doc-groups

# Session limits
# CLAUDE_SESSION_TIMEOUT_MS=1800000
# CLAUDE_RESPONSE_TIMEOUT_MS=1200000
# CLAUDE_MAX_CONCURRENT_SESSIONS=10

# =============================================================================
# Observability & Logging
# =============================================================================

LOG_LEVEL=info

# Langfuse (optional — for agent execution tracing)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# =============================================================================
# Application Settings
# =============================================================================

# Avatar generation via Amazon Bedrock Nova Canvas
ENABLE_AVATAR_GENERATION=false

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# Agent Runtime Selection
# =============================================================================
# "claude"     — local Claude Agent SDK subprocess (default)
# "agentcore"  — Claude Agent SDK inside Bedrock AgentCore containers
# "openclaw"   — OpenClaw inside Bedrock AgentCore containers

AGENT_RUNTIME=agentcore
# AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789:agent-runtime/your-runtime-id
# AGENTCORE_ENDPOINT_NAME=your-endpoint-name
# AGENTCORE_BASE_IMAGE=123456789.dkr.ecr.us-east-1.amazonaws.com/super-agent-agentcore:latest
# AGENTCORE_EXECUTION_ROLE_ARN=arn:aws:iam::123456789:role/AgentCoreExecutionRole
# AGENTCORE_BACKEND_API_URL=https://api.super-agent.example.com
# AGENTCORE_BACKEND_API_KEY=sk-internal-...
# AGENTCORE_WORKSPACE_S3_BUCKET=super-agent-workspaces
# OPENCLAW_AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789:agent-runtime/openclaw-runtime-id

VECTOR_MEMORY_ENABLED=false
RAG_ENABLED=false

# Bedrock-specific AWS credentials (optional, falls back to AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY)
# BEDROCK_AWS_ACCESS_KEY_ID=your-bedrock-access-key-id
# BEDROCK_AWS_SECRET_ACCESS_KEY=your-bedrock-secret-access-key

API_BASE_URL=http://localhost:5173

LITELLM_BASE_URL=xxx
LITELLM_API_KEY=sk-xxx

# =============================================================================
# InsForge Backend-as-a-Service (shared instance for app backends)
# =============================================================================
# When enabled, published apps can have their own PostgreSQL schema
# within a shared InsForge instance. Agents access app data via MCP.
# Run: cd insforge-local && docker compose -f docker-compose.prod.yml up -d
INSFORGE_ENABLED=false
INSFORGE_HOST=localhost
INSFORGE_PORT_APP=17130
INSFORGE_PORT_AUTH=17131
INSFORGE_PORT_POSTGREST=15430
INSFORGE_PORT_POSTGRES=15432
INSFORGE_PORT_DENO=17133
INSFORGE_API_KEY=ik_your_insforge_api_key_here
INSFORGE_PG_USER=postgres
INSFORGE_PG_PASSWORD=postgres
INSFORGE_PG_DB=insforge
