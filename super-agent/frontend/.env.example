# =============================================================================
# API Mode Configuration
# =============================================================================
# Set to 'rest' to use REST API backend (backend)
# Set to 'supabase' (or leave empty) to use Supabase direct access
VITE_API_MODE=rest

# REST API Backend URL (used when VITE_API_MODE=rest)
VITE_API_BASE_URL=http://localhost:3000

# =============================================================================
# Supabase Configuration (used when VITE_API_MODE=supabase)
# =============================================================================
# Get these values from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Mode Configuration
# Set to 'true' to use mock services (development), 'false' to use Supabase (production)
VITE_USE_MOCK=true

# Avatar Generation Configuration
# Set to 'true' to enable Nova Canvas avatar generation, 'false' to use letter initials
VITE_ENABLE_AVATAR_GENERATION=false

# Default Organization ID (for development without authentication)
# This is used for real-time subscriptions when no user is authenticated.
# Get this from your seed data or create an organization in Supabase.
VITE_DEFAULT_ORG_ID=
